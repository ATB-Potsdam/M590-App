<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Hintergrundfarbe deiner App (kein weißer Blitz): -->
        <item name="android:windowSplashScreenBackground">@color/colorSplashBackground</item>
        <!-- Icon komplett entfernen: -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent</item>
        <!-- Keine Anzeige-Dauer: -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>